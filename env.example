# FRED API Configuration
# Get your free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
# Copy this file to .env and set real values (never commit .env).
FRED_API_KEY=

# Optional: Override default date range
# START_DATE=2020-01-01
# END_DATE=2024-12-31

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=